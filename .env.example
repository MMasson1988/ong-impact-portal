# --- Django core ---
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=change-me-to-a-long-random-string-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database (development: SQLite by default) ---
# DATABASE_URL=sqlite:///db.sqlite3

# --- PostgreSQL (production) ---
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=ong_impact_portal
# DB_USER=portal_user
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=5432

# --- Media & static ---
MEDIA_ROOT=media
PRIVATE_MEDIA_ROOT=private_media

# --- Email (optional) ---
# EMAIL_HOST=smtp.example.org
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=noreply@ong-impact-portal.org

# --- Security (production) ---
# CSRF_TRUSTED_ORIGINS=https://votre-domaine.org
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
